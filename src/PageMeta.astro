---
import type { IOpenGraphAudioArgs, IOpenGraphImageArgs, IOpenGraphVideoArgs } from './IOpenGraph.interface';
import type { IPageMeta } from './IPageMeta.interface';

type Props = IPageMeta;

// Cast to any so union-discriminated props (article, profile, book, video.*, music.*, payment:link,
// twitter:player, twitter:app) can all be destructured without requiring per-branch type narrowing.
const {
    // IPageMeta
    author = 'Kai Orion',
    sitemap = '/sitemap-index.xml',
    robots = 'index, follow',
    title,
    description,
    keywords = 'kai orion, sandlada',
    applicationName,
    referrer = 'strict-origin-when-cross-origin',
    colorScheme = 'light dark',
    themeColorDark = '#000000',
    themeColorLight = '#ffffff',
    themeColorLightMedia = '(prefers-color-scheme: light)',
    themeColorDarkMedia = '(prefers-color-scheme: dark)',
    url,
    icon,
    image,
    imageAlt,
    articleModifiedTime,
    // IAstro
    generator = Astro.generator,
    // IOpenGraph — base
    ogType = 'website',
    ogTitle,
    ogUrl,
    ogImage,
    ogDescription,
    ogDeterminer,
    ogLocale = 'en-US',
    ogLocaleAlternate,
    ogSiteName,
    ogAudio,
    ogVideo,
    // IOpenGraph — article
    ogArticlePublishedTime,
    ogArticleModifiedTime,
    ogArticleExpirationTime,
    ogArticleAuthor,
    ogArticleSection,
    ogArticleTag,
    // IOpenGraph — profile
    ogProfileFirstName,
    ogProfileLastName,
    ogProfileUsername,
    ogProfileGender,
    // IOpenGraph — book
    ogBookAuthor,
    ogBookIsbn,
    ogBookReleaseDate,
    ogBookTag,
    // IOpenGraph — video.* (type-level metadata, distinct from og:video media attachment)
    ogVideoActor,
    ogVideoActorRole,
    ogVideoDirector,
    ogVideoWriter,
    ogVideoDuration,
    ogVideoReleaseDate,
    ogVideoTag,
    ogVideoSeries,
    // IOpenGraph — music.*
    ogMusicDuration,
    ogMusicAlbum,
    ogMusicAlbumDisc,
    ogMusicAlbumTrack,
    ogMusicMusician,
    ogMusicSong,
    ogMusicSongDisc,
    ogMusicSongTrack,
    ogMusicReleaseDate,
    ogMusicCreator,
    // IOpenGraph — payment:link
    ogPaymentDescription,
    ogPaymentCurrency,
    ogPaymentAmount,
    ogPaymentExpiresAt,
    ogPaymentStatus,
    ogPaymentId,
    ogPaymentSuccessUrl,
    // ITwitterCard — base
    twitterCard = 'summary_large_image',
    twitterSite,
    twitterCreator,
    twitterTitle,
    twitterDescription,
    twitterImage,
    twitterImageAlt,
    twitterLabel1,
    twitterData1,
    twitterLabel2,
    twitterData2,
    // ITwitterCard — player
    twitterPlayer,
    twitterPlayerWidth,
    twitterPlayerHeight,
    twitterPlayerStream,
    twitterPlayerStreamContentType,
    // ITwitterCard — app
    twitterAppNameIphone,
    twitterAppIdIphone,
    twitterAppUrlIphone,
    twitterAppNameIpad,
    twitterAppIdIpad,
    twitterAppUrlIpad,
    twitterAppNameGoogleplay,
    twitterAppIdGoogleplay,
    twitterAppUrlGoogleplay,
    twitterAppCountry,
} = Astro.props as any;

// Normalize OGImage / OGAudio / OGVideo unions to typed arrays
function toOgImageList(val: unknown): IOpenGraphImageArgs[] {
    if (!val) return [];
    const items = Array.isArray(val) ? val : [val];
    return items.map((item: unknown) =>
        typeof item === 'string' ? { ogImageUrl: item } : (item as IOpenGraphImageArgs)
    );
}
function toOgAudioList(val: unknown): IOpenGraphAudioArgs[] {
    if (!val) return [];
    const items = Array.isArray(val) ? val : [val];
    return items.map((item: unknown) =>
        typeof item === 'string' ? { ogAudioUrl: item } : (item as IOpenGraphAudioArgs)
    );
}
function toOgVideoList(val: unknown): IOpenGraphVideoArgs[] {
    if (!val) return [];
    const items = Array.isArray(val) ? val : [val];
    return items.map((item: unknown) =>
        typeof item === 'string' ? { ogVideoUrl: item } : (item as IOpenGraphVideoArgs)
    );
}
function toStrings(val: unknown): string[] {
    if (!val) return [];
    return Array.isArray(val) ? val : [val as string];
}

const ogImageList    = toOgImageList(ogImage);
const ogAudioList    = toOgAudioList(ogAudio);
const ogVideoList    = toOgVideoList(ogVideo);
const localeAlts     = toStrings(ogLocaleAlternate);
const articleAuthors = toStrings(ogArticleAuthor);
const articleTags    = toStrings(ogArticleTag);
const bookAuthors    = toStrings(ogBookAuthor);
const bookTags       = toStrings(ogBookTag);
const videoActors    = toStrings(ogVideoActor);
const videoActorRoles = toStrings(ogVideoActorRole);
const videoDirectors = toStrings(ogVideoDirector);
const videoWriters   = toStrings(ogVideoWriter);
const videoTags      = toStrings(ogVideoTag);
const musicAlbums    = toStrings(ogMusicAlbum);
const musicMusicians = toStrings(ogMusicMusician);
const musicSongs     = toStrings(ogMusicSong);
const musicCreators  = toStrings(ogMusicCreator);
const twitterImages  = toStrings(twitterImage);
---

<title>{title ?? 'Untitled Page'}</title>

<!-- Document -->
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<meta name="description" content={description} />
<meta name="author" content={author} />
<meta name="generator" content={generator} />
<meta name="keywords" content={keywords} />
<meta name="robots" content={robots} />
<meta name="referrer" content={referrer} />
{applicationName && <meta name="application-name" content={applicationName} />}

<!-- Color / Theme -->
<meta name="color-scheme" content={colorScheme} />
<meta name="theme-color" content={themeColorLight} media={themeColorLightMedia} />
<meta name="theme-color" content={themeColorDark} media={themeColorDarkMedia} />

<!-- Links -->
{url && <link rel="canonical" href={url} />}
<link rel="sitemap" href={sitemap} />
{icon && <link rel="icon" type="image/svg+xml" href={icon.src} />}

<!-- article:modified_time shorthand (IPageMeta direct prop) -->
{articleModifiedTime && <meta property="article:modified_time" content={articleModifiedTime} />}

<!-- Open Graph — base -->
<meta property="og:type" content={ogType} />
<meta property="og:title" content={ogTitle ?? title} />
<meta property="og:description" content={ogDescription ?? description} />
<meta property="og:locale" content={ogLocale} />
{localeAlts.map(alt => <meta property="og:locale:alternate" content={alt} />)}
<meta property="og:site_name" content={ogSiteName ?? title} />
{(ogUrl || url) && <meta property="og:url" content={ogUrl ?? url} />}
{ogDeterminer !== undefined && <meta property="og:determiner" content={ogDeterminer} />}

<!-- OG Image(s) — string / IOpenGraphImageArgs / mixed array -->
{ogImageList.length > 0
    ? ogImageList.map(img => (
        <>
            <meta property="og:image" content={img.ogImageUrl} />
            {img.ogImageSecureUrl && <meta property="og:image:secure_url" content={img.ogImageSecureUrl} />}
            {img.ogImageType && <meta property="og:image:type" content={img.ogImageType} />}
            {img.ogImageWidth != null && <meta property="og:image:width" content={String(img.ogImageWidth)} />}
            {img.ogImageHeight != null && <meta property="og:image:height" content={String(img.ogImageHeight)} />}
            {(img.ogImageAlt || imageAlt) && <meta property="og:image:alt" content={img.ogImageAlt ?? imageAlt} />}
        </>
    ))
    : image && (
        <>
            <meta property="og:image" content={image.src} />
            {imageAlt && <meta property="og:image:alt" content={imageAlt} />}
        </>
    )
}

<!-- OG Audio -->
{ogAudioList.map(audio => (
    <>
        <meta property="og:audio" content={audio.ogAudioUrl} />
        {audio.ogAudioSecureUrl && <meta property="og:audio:secure_url" content={audio.ogAudioSecureUrl} />}
        {audio.ogAudioType && <meta property="og:audio:type" content={audio.ogAudioType} />}
    </>
))}

<!-- OG Video (media attachment) -->
{ogVideoList.map(video => (
    <>
        <meta property="og:video" content={video.ogVideoUrl} />
        {video.ogVideoSecureUrl && <meta property="og:video:secure_url" content={video.ogVideoSecureUrl} />}
        {video.ogVideoType && <meta property="og:video:type" content={video.ogVideoType} />}
        {video.ogVideoWidth != null && <meta property="og:video:width" content={String(video.ogVideoWidth)} />}
        {video.ogVideoHeight != null && <meta property="og:video:height" content={String(video.ogVideoHeight)} />}
    </>
))}

<!-- OG Type: article -->
{ogType === 'article' && (
    <>
        {ogArticlePublishedTime && <meta property="article:published_time" content={ogArticlePublishedTime} />}
        {ogArticleModifiedTime && <meta property="article:modified_time" content={ogArticleModifiedTime} />}
        {ogArticleExpirationTime && <meta property="article:expiration_time" content={ogArticleExpirationTime} />}
        {articleAuthors.map(a => <meta property="article:author" content={a} />)}
        {ogArticleSection && <meta property="article:section" content={ogArticleSection} />}
        {articleTags.map(t => <meta property="article:tag" content={t} />)}
    </>
)}

<!-- OG Type: profile -->
{ogType === 'profile' && (
    <>
        {ogProfileFirstName && <meta property="profile:first_name" content={ogProfileFirstName} />}
        {ogProfileLastName && <meta property="profile:last_name" content={ogProfileLastName} />}
        {ogProfileUsername && <meta property="profile:username" content={ogProfileUsername} />}
        {ogProfileGender && <meta property="profile:gender" content={ogProfileGender} />}
    </>
)}

<!-- OG Type: book -->
{ogType === 'book' && (
    <>
        {bookAuthors.map(a => <meta property="book:author" content={a} />)}
        {ogBookIsbn && <meta property="book:isbn" content={ogBookIsbn} />}
        {ogBookReleaseDate && <meta property="book:release_date" content={ogBookReleaseDate} />}
        {bookTags.map(t => <meta property="book:tag" content={t} />)}
    </>
)}

<!-- OG Type: video.* -->
{(ogType === 'video.movie' || ogType === 'video.episode' || ogType === 'video.tv_show' || ogType === 'video.other') && (
    <>
        {videoActors.map(a => <meta property="video:actor" content={a} />)}
        {videoActorRoles.map(r => <meta property="video:actor:role" content={r} />)}
        {videoDirectors.map(d => <meta property="video:director" content={d} />)}
        {videoWriters.map(w => <meta property="video:writer" content={w} />)}
        {ogVideoDuration != null && <meta property="video:duration" content={String(ogVideoDuration)} />}
        {ogVideoReleaseDate && <meta property="video:release_date" content={ogVideoReleaseDate} />}
        {videoTags.map(t => <meta property="video:tag" content={t} />)}
        {ogType === 'video.episode' && ogVideoSeries && <meta property="video:series" content={ogVideoSeries} />}
    </>
)}

<!-- OG Type: music:song -->
{ogType === 'music:song' && (
    <>
        {ogMusicDuration != null && <meta property="music:duration" content={String(ogMusicDuration)} />}
        {musicAlbums.map(a => <meta property="music:album" content={a} />)}
        {ogMusicAlbumDisc != null && <meta property="music:album:disc" content={String(ogMusicAlbumDisc)} />}
        {ogMusicAlbumTrack != null && <meta property="music:album:track" content={String(ogMusicAlbumTrack)} />}
        {musicMusicians.map(m => <meta property="music:musician" content={m} />)}
    </>
)}

<!-- OG Type: music:album -->
{ogType === 'music:album' && (
    <>
        {musicSongs.map(s => <meta property="music:song" content={s} />)}
        {ogMusicSongDisc != null && <meta property="music:song:disc" content={String(ogMusicSongDisc)} />}
        {ogMusicSongTrack != null && <meta property="music:song:track" content={String(ogMusicSongTrack)} />}
        {musicMusicians.map(m => <meta property="music:musician" content={m} />)}
        {ogMusicReleaseDate && <meta property="music:release_date" content={ogMusicReleaseDate} />}
    </>
)}

<!-- OG Type: music:playlist -->
{ogType === 'music:playlist' && (
    <>
        {musicSongs.map(s => <meta property="music:song" content={s} />)}
        {ogMusicSongDisc != null && <meta property="music:song:disc" content={String(ogMusicSongDisc)} />}
        {ogMusicSongTrack != null && <meta property="music:song:track" content={String(ogMusicSongTrack)} />}
        {musicCreators.map(c => <meta property="music:creator" content={c} />)}
    </>
)}

<!-- OG Type: music:radio_station -->
{ogType === 'music:radio_station' && (
    <>
        {musicCreators.map(c => <meta property="music:creator" content={c} />)}
    </>
)}

<!-- OG Type: payment:link -->
{ogType === 'payment:link' && (
    <>
        {ogPaymentDescription && <meta property="payment:description" content={ogPaymentDescription} />}
        {ogPaymentCurrency && <meta property="payment:currency" content={ogPaymentCurrency} />}
        {ogPaymentAmount != null && <meta property="payment:amount" content={String(ogPaymentAmount)} />}
        {ogPaymentExpiresAt && <meta property="payment:expires_at" content={ogPaymentExpiresAt} />}
        {ogPaymentStatus && <meta property="payment:status" content={ogPaymentStatus} />}
        {ogPaymentId && <meta property="payment:id" content={ogPaymentId} />}
        {ogPaymentSuccessUrl && <meta property="payment:success_url" content={ogPaymentSuccessUrl} />}
    </>
)}

<!-- Twitter Card — base -->
<meta name="twitter:card" content={twitterCard} />
{twitterSite && <meta name="twitter:site" content={twitterSite} />}
{twitterCreator && <meta name="twitter:creator" content={twitterCreator} />}
<meta name="twitter:title" content={twitterTitle ?? title} />
<meta name="twitter:description" content={twitterDescription ?? description} />
{(twitterImages[0] || image) && <meta name="twitter:image" content={twitterImages[0] ?? image?.src} />}
{(twitterImageAlt || imageAlt) && <meta name="twitter:image:alt" content={twitterImageAlt ?? imageAlt} />}
{twitterLabel1 && <meta name="twitter:label1" content={twitterLabel1} />}
{twitterData1 && <meta name="twitter:data1" content={twitterData1} />}
{twitterLabel2 && <meta name="twitter:label2" content={twitterLabel2} />}
{twitterData2 && <meta name="twitter:data2" content={twitterData2} />}

<!-- Twitter Card — player -->
{twitterCard === 'player' && (
    <>
        {twitterPlayer && <meta name="twitter:player" content={twitterPlayer} />}
        {twitterPlayerWidth != null && <meta name="twitter:player:width" content={String(twitterPlayerWidth)} />}
        {twitterPlayerHeight != null && <meta name="twitter:player:height" content={String(twitterPlayerHeight)} />}
        {twitterPlayerStream && <meta name="twitter:player:stream" content={twitterPlayerStream} />}
        {twitterPlayerStreamContentType && <meta name="twitter:player:stream:content_type" content={twitterPlayerStreamContentType} />}
    </>
)}

<!-- Twitter Card — app -->
{twitterCard === 'app' && (
    <>
        {twitterAppNameIphone && <meta name="twitter:app:name:iphone" content={twitterAppNameIphone} />}
        {twitterAppIdIphone && <meta name="twitter:app:id:iphone" content={twitterAppIdIphone} />}
        {twitterAppUrlIphone && <meta name="twitter:app:url:iphone" content={twitterAppUrlIphone} />}
        {twitterAppNameIpad && <meta name="twitter:app:name:ipad" content={twitterAppNameIpad} />}
        {twitterAppIdIpad && <meta name="twitter:app:id:ipad" content={twitterAppIdIpad} />}
        {twitterAppUrlIpad && <meta name="twitter:app:url:ipad" content={twitterAppUrlIpad} />}
        {twitterAppNameGoogleplay && <meta name="twitter:app:name:googleplay" content={twitterAppNameGoogleplay} />}
        {twitterAppIdGoogleplay && <meta name="twitter:app:id:googleplay" content={twitterAppIdGoogleplay} />}
        {twitterAppUrlGoogleplay && <meta name="twitter:app:url:googleplay" content={twitterAppUrlGoogleplay} />}
        {twitterAppCountry && <meta name="twitter:app:country" content={twitterAppCountry} />}
    </>
)}
