---
import PageMeta from '../PageMeta.astro';
---

<!doctype html>
<html lang="en">
    <head>
        <PageMeta
            title="BBC World Service — Live Radio | BBC"
            description="BBC World Service broadcasts to the world on radio, on TV, and online, with news and current affairs, as well as arts, sport, and features."
            url="https://www.bbc.co.uk/worldservice"
            ogType="music:radio_station"
            ogTitle="BBC World Service"
            ogDescription="Global news, analysis and features in English, 24 hours a day."
            ogUrl="https://www.bbc.co.uk/worldservice"
            ogLocale="en-GB"
            ogSiteName="BBC"
            ogImage="https://placehold.co/1200x630/png?text=BBC+World+Service"
            ogMusicCreator={['https://www.bbc.co.uk/', 'https://en.wikipedia.org/wiki/BBC_World_Service']}
            twitterCard="summary"
            twitterSite="@BBCWorld"
            twitterImage="https://placehold.co/1200x630/png?text=BBC+World+Service"
        />
    </head>
    <body>
        <h1>og:type = music:radio_station</h1>
        <ul>
            <li><strong>Subject</strong>: BBC World Service — global English-language radio</li>
            <li><strong>og:type</strong>: music:radio_station</li>
            <li><strong>music:creator</strong>: [bbc.co.uk, BBC World Service Wikipedia URL]</li>
            <li><strong>twitter:site</strong>: @BBCWorld</li>
        </ul>
    </body>
</html>
