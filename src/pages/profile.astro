---
import PageMeta from '../PageMeta.astro';
---

<!doctype html>
<html lang="en">
    <head>
        <PageMeta
            title="Linus Torvalds — Wikipedia"
            description="Linus Benedict Torvalds is a Finnish-American software engineer who is the creator and lead developer of the Linux kernel."
            url="https://en.wikipedia.org/wiki/Linus_Torvalds"
            ogType="profile"
            ogTitle="Linus Torvalds — Wikipedia"
            ogDescription="Finnish-American software engineer, creator of the Linux kernel and Git."
            ogUrl="https://en.wikipedia.org/wiki/Linus_Torvalds"
            ogLocale="en-US"
            ogSiteName="Wikipedia"
            ogImage="https://upload.wikimedia.org/wikipedia/commons/0/01/LinuxCon_Europe_Linus_Torvalds_03_%28cropped%29.jpg"
            ogProfileFirstName="Linus"
            ogProfileLastName="Torvalds"
            ogProfileUsername="torvalds"
            ogProfileGender="male"
            twitterCard="summary"
            twitterSite="@Wikipedia"
            twitterCreator="@Wikipedia"
        />
    </head>
    <body>
        <h1>og:type = profile</h1>
        <ul>
            <li><strong>Subject</strong>: Linus Torvalds — Wikipedia</li>
            <li><strong>og:type</strong>: profile</li>
            <li><strong>og:image</strong>: Wikimedia Commons direct JPG URL</li>
            <li><strong>profile:first_name</strong>: Linus</li>
            <li><strong>profile:last_name</strong>: Torvalds</li>
            <li><strong>profile:username</strong>: torvalds (GitHub username)</li>
            <li><strong>profile:gender</strong>: male</li>
            <li><strong>twitter:card</strong>: summary</li>
            <li><strong>twitter:site</strong>: @Wikipedia</li>
        </ul>
    </body>
</html>
